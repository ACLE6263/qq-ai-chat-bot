# ===== NoneBot2 Core =====
ENVIRONMENT=prod
DRIVER=~fastapi
HOST=127.0.0.1
PORT=8080

# ===== OneBot v11 (must match NapCat config) =====
# IMPORTANT: Both sides must be empty to skip auth verification.
# If you set a token, NoneBot2 checks the Authorization header while
# NapCat sends it via URL query parameter — mismatch causes 403.
ONEBOT_ACCESS_TOKEN=

# ===== AI Provider Selection =====
# Choose one: claude | openai | custom
# "custom" works with any OpenAI-compatible endpoint (DeepSeek, Ollama, vLLM, etc.)
LLM_PROVIDER=custom

# --- DeepSeek (recommended: cheap and capable) ---
CUSTOM_API_BASE=https://api.deepseek.com/v1
CUSTOM_API_KEY=your-deepseek-api-key-here
CUSTOM_MODEL=deepseek-chat
# Fallback models (comma-separated), tried in order if primary fails
CUSTOM_BACKUP_MODELS=

# --- Claude (highest quality) ---
# LLM_PROVIDER=claude
# CLAUDE_API_KEY=your-claude-api-key-here
# CLAUDE_API_BASE=https://api.anthropic.com
# CLAUDE_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ===== AI Behavior =====
# System prompt can be set here or in system_prompt.txt (file takes priority)
SYSTEM_PROMPT=你是一个运行在 QQ 上的 AI 助手，请用简洁友好的方式回复。
MAX_HISTORY_TURNS=20
MAX_RESPONSE_TOKENS=1024
TEMPERATURE=0.7

# Group chat trigger mode:
#   at_only — only respond when @mentioned (default)
#   prefix  — respond when message starts with CHAT_PREFIX
TRIGGER_MODE=at_only
CHAT_PREFIX=/chat

# ===== HTTP Proxy (optional, httpx doesn't use system proxy) =====
# HTTP_PROXY=http://127.0.0.1:7890

# ===== Rate Limiting =====
RATE_LIMIT_PER_USER=20
RATE_LIMIT_PER_GROUP=60
RATE_LIMIT_WINDOW=60

# ===== Bot Owner QQ (admin commands only respond to this number) =====
BOT_OWNER_QQ=your-qq-number-here
